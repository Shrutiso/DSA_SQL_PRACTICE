--Aggregate functions.
--1. Total Salary of All Employees (SUM)
--2. Average Salary (AVG)
--3. Highest Salary (MAX)
--4. Lowest Salary (MIN)
--5. Count Total Employees (COUNT)
--6. Department-wise Employee Count (GROUP BY)
--7. Department-wise Total Salary
--8. Department-wise Average Salary
--9. Department-wise Highest Salary
--10. Departments Having More Than 2 Employees (HAVING)
--11. Departments with Average Salary Greater Than 45,000
--12. Cities Having More Than 2 Employees
--13. Employees Ordered by Salary (Highest to Lowest)
--14. Employees Ordered by Department and Salary
--15. Department-wise Total Salary Greater Than 100000

create table Employee(
     emp_id int primary key,
    e_name varchar(20),
    e_dept varchar(30),
    e_salary int,
    e_age int,
    e_address varchar(50)
);
