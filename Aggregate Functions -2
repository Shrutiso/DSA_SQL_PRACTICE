select * from Employee;

select sum(e_salary) as Total_Salary_sum from  Employee ;
select avg(e_salary)  from  Employee ;
select max(e_salary) from Employee ;
select min(e_salary) from  Employee ;
select count(emp_id) from  Employee ;
select count(emp_id) , e_dept from Employee
group by e_dept;
select sum(e_salary) , e_dept from Employee
group by e_dept;

select avg(e_salary) , e_dept from Employee
group by e_dept;

select max(e_salary) , e_dept from Employee
group by e_dept;

select count(emp_id) , e_dept from Employee having count(emp_id) >2;
SELECT e_dept
FROM Employee
GROUP BY e_dept
HAVING AVG(e_salary) > 45000;

select e_address from Employee
group by e_address
having count(emp_id) >2;

select e_salary , e_name from Employee
order by e_salary desc;

select e_name , e_dept , e_salary from Employee
order by e_salary asc;

select e_dept , e_salary from Employee
group by e_dept
having sum(e_salary) > 100000;






















