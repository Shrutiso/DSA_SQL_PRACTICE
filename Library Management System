--USE library_management;

-- 3. Create Books Table
CREATE TABLE Books (
    book_name VARCHAR(50),
    author_name VARCHAR(50),
    book_price INT NOT NULL,
    qty int
);

-- 4. Create Members Table
CREATE TABLE Members (
    name VARCHAR(30)
);

-- 5. Create Issue Table
CREATE TABLE Issue (
    book_name VARCHAR(50),
    issue_date DATE,
    issued_by VARCHAR(50)
);
