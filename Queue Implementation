//Queue implemenation
import java.util.*;
class Main{
    public static void main (String args[]){
        Queue<Integer>q = new LinkedList<>();
        q.add(10);
        q.add(20);
        q.add(30);
        q.add(40);
        q.add(50);
        System.out.println(q);
        System.out.println(q.peek());
        System.out.println(q.isEmpty());
        
        for (int num : q) {
            System.out.println(num);
        }
    }
}


        
    
