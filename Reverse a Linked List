//Reverse a linked list 
import java.util.*;
class Main{
    public static void main(String args[]){
        LinkedList<Integer> list = new LinkedList<>();
        list.add(10);
        list.add(20);
        list.add(30);
        list.add(40);
        list.add(50);
        Collections.reverse(list);
        System.out.println(list);
        
    }
}
